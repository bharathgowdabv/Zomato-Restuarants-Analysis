--Location column
SELECT
location,
    CASE 
        WHEN location IS NULL OR location = 'NULL' THEN 'UNKNOWN'
        WHEN CHARINDEX(',', location) > 0 
            THEN LTRIM(RTRIM(RIGHT(location, LEN(location) - CHARINDEX(',', location))))
        ELSE LTRIM(RTRIM(location))
    END AS clean_location
FROM zomato_raw;

