--Rate column
SELECT DISTINCT
rate
FROM zomato_raw;
--Keep all valid ratings and Convert only invalid/unusable values to NULL
SELECT 
rate,
CASE WHEN rate IN ('NEW','-','NULL') THEN NULL
ELSE TRY_CAST(REPLACE(REPLACE(LTRIM(RTRIM(rate)), '/5', ''), ' ', '') AS FLOAT)
END
FROM zomato_raw;

