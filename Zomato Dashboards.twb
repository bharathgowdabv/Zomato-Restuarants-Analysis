                  <zone forceUpdate='true' h='17250' id='25' type-v2='text' w='98666' x='667' y='81750'>
                    <formatted-text>
                      <run bold='true' fontcolor='#1f4e79' fontname='Arial' fontsize='12'>Key Insights from Market Quadrant Analysis</run>
                      <run>Æ&#10;</run>
                      <run bold='true' fontcolor='#333333' fontname='Arial' fontsize='10'>Hidden Gems (Blue):</run>
                      <run fontcolor='#333333' fontname='Arial' fontsize='10'> Neighbourhood offer high quality ratings with low competition- ideal locations for new restaurant openings</run>
                      <run>Æ&#10;</run>
                      <run bold='true' fontcolor='#333333' fontname='Arial' fontsize='10'>Saturated Markets (Red):</run>
                      <run fontcolor='#333333' fontname='Arial' fontsize='10'> Neighbourhood have the highest competition but ratings below the city average- difficult entry conditions</run>
                      <run>Æ&#10;</run>
                      <run bold='true' fontcolor='#333333' fontname='Arial' fontsize='10'>Quality Leaders (Green):</run>
                      <run fontcolor='#333333' fontname='Arial' fontsize='10'> Neighbourhood consistently outperform on both rating and popularity despite high competition</run>
                      <run>Æ&#10;</run>
                      <run bold='true' fontcolor='#27ae60' fontname='Arial' fontsize='10'>A new restaurant</run>
                      <run fontcolor='#27ae60' fontname='Arial' fontsize='10'> targeting should consider neighbourhoods represented by blue- high demand, low supply, and strong existing ratings in that area</run>
                    </formatted-text>
                    <zone-style>
                      <format attr='border-color' value='#f0d080' />
                      <format attr='border-style' value='solid' />
                      <format attr='border-width' value='3' />
                      <format attr='margin' value='4' />
                      <format attr='padding' value='4' />
                      <format attr='padding-top' value='12' />
                      <format attr='padding-right' value='8' />
                      <format attr='padding-bottom' value='12' />
                      <format attr='padding-left' value='8' />
                      <format attr='background-color' value='#fff9e6' />
                    </zone-style>
                  </zone>
