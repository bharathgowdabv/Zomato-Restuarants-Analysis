              <zone h='87375' id='19' param='vert' type-v2='layout-flow' w='98666' x='667' y='11625'>
                <zone fixed-size='570' h='70125' id='20' is-fixed='true' name='3_Market Quadrant Scatter' show-title='false' w='98666' x='667' y='11625'>
                  <layout-cache minheight='163' minwidth='164' type-h='scalable' type-w='scalable' />
                  <zone-style>
                    <format attr='border-color' value='#dddddd' />
                    <format attr='border-style' value='solid' />
