      </style>
      <size maxheight='800' maxwidth='1200' minheight='800' minwidth='1200' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='10' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='23' layout-strategy-id='distribute-evenly' param='horz' type-v2='layout-flow' w='98666' x='667' y='1000'>
            <zone h='98000' id='21' type-v2='layout-basic' w='98666' x='667' y='1000'>
              <zone h='10625' id='9' type-v2='text' w='68083' x='667' y='1000'>
                <formatted-text>
